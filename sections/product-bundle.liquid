{%- liquid
  assign bundle_variants = product.metafields.custom.component_variants.value
  assign has_compare = false
  if product.compare_at_price > product.price
    assign has_compare = true
  endif
-%}

<div class="bundle-page page-width">
  <div class="bundle-page__grid">

    <div class="bundle-page__media">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 700 }}"
          alt="{{ product.featured_image.alt | escape }}"
          width="700"
          height="700"
          loading="eager"
          class="bundle-page__image"
        >
      {%- endif -%}
    </div>

    <div class="bundle-page__info">
      <h1 class="bundle-page__title">{{ product.title }}</h1>

      <div class="bundle-page__price">
        {%- if has_compare -%}
          <s class="bundle-page__compare-price">{{ product.compare_at_price | money }}</s>
        {%- endif -%}
        <span class="bundle-page__current-price">{{ product.price | money }}</span>
        {%- if has_compare -%}
          {%- assign savings = product.compare_at_price | minus: product.price -%}
          <span class="bundle-page__savings">Save {{ savings | money }}</span>
        {%- endif -%}
      </div>

      {%- if product.description != blank -%}
        <div class="bundle-page__description rte">{{ product.description }}</div>
      {%- endif -%}

      {%- if bundle_variants and bundle_variants.size > 0 -%}
        <div class="bundle-page__components">
          <p class="bundle-page__components-heading">What's included</p>
          <ul class="bundle-page__component-list">
            {%- for v in bundle_variants -%}
              <li class="bundle-page__component-item">
                {%- assign thumb = v.image | default: v.product.featured_image -%}
                {%- if thumb -%}
                  <img
                    src="{{ thumb | image_url: width: 120 }}"
                    alt="{{ thumb.alt | escape }}"
                    width="60"
                    height="60"
                    loading="lazy"
                    class="bundle-page__component-img"
                  >
                {%- endif -%}
                <div class="bundle-page__component-info">
                  <span class="bundle-page__component-title">{{ v.product.title }}</span>
                  {%- unless v.title == 'Default Title' -%}
                    <span class="bundle-page__component-variant">{{ v.title }}</span>
                  {%- endunless -%}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <button
        class="button bundle-page__add-btn"
        id="bundle-add-to-cart"
        type="button"
        {%- unless bundle_variants and bundle_variants.size > 0 -%}disabled{%- endunless -%}
      >
        {{ section.settings.button_text }}
      </button>

      <p class="bundle-page__feedback" id="bundle-feedback" aria-live="polite"></p>
    </div>

  </div>
</div>

<script>
(function () {
  var ids = [
    {%- for v in bundle_variants -%}{{ v.id }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
  ];

  var btn = document.getElementById('bundle-add-to-cart');
  var feedback = document.getElementById('bundle-feedback');
  var defaultLabel = btn ? btn.textContent.trim() : '';

  if (!btn || !ids.length) return;

  btn.addEventListener('click', function () {
    btn.disabled = true;
    btn.textContent = 'Adding…';
    feedback.textContent = '';
    feedback.className = 'bundle-page__feedback';

    var items = ids.map(function (id) { return { id: id, quantity: 1 }; });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
      .then(function (r) {
        if (!r.ok) return r.json().then(function (d) { throw new Error(d.description || 'Error'); });
        return r.json();
      })
      .then(function () {
        btn.textContent = 'Added ✓';
        feedback.textContent = 'Bundle added to your cart.';
        feedback.className = 'bundle-page__feedback bundle-page__feedback--success';

        // Open cart drawer (Horizon)
        var drawer = document.querySelector('cart-drawer-component');
        if (drawer && typeof drawer.open === 'function') {
          drawer.open();
        } else {
          var toggle = document.querySelector('[aria-controls="CartDrawer"], [data-cart-toggle], .js-cart-drawer-toggle');
          if (toggle) toggle.click();
        }

        // Refresh cart count bubble via section render
        fetch('/?sections=cart-bubble')
          .then(function (r) { return r.json(); })
          .then(function (data) {
            if (data && data['cart-bubble']) {
              var tmp = document.createElement('div');
              tmp.innerHTML = data['cart-bubble'];
              var newBubble = tmp.querySelector('cart-bubble, .cart-bubble, [data-cart-count]');
              var existing = document.querySelector('cart-bubble, .cart-bubble, [data-cart-count]');
              if (newBubble && existing) existing.outerHTML = newBubble.outerHTML;
            }
          })
          .catch(function () {});

        setTimeout(function () {
          btn.disabled = false;
          btn.textContent = defaultLabel;
          feedback.textContent = '';
        }, 3000);
      })
      .catch(function (err) {
        btn.disabled = false;
        btn.textContent = defaultLabel;
        feedback.textContent = err.message || 'Something went wrong. Please try again.';
        feedback.className = 'bundle-page__feedback bundle-page__feedback--error';
      });
  });
})();
</script>

{% stylesheet %}
.bundle-page {
  padding: 2.5rem 1rem 5rem;
}

.bundle-page__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3.5rem;
  align-items: start;
  max-width: 1100px;
  margin: 0 auto;
}

@media (max-width: 749px) {
  .bundle-page__grid {
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
}

.bundle-page__image {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 8px;
  display: block;
}

.bundle-page__title {
  font-size: 1.75rem;
  font-weight: 700;
  margin: 0 0 0.75rem;
  line-height: 1.2;
}

.bundle-page__price {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
}

.bundle-page__current-price {
  font-size: 1.3rem;
  font-weight: 700;
}

.bundle-page__compare-price {
  font-size: 1rem;
  opacity: 0.45;
  text-decoration: line-through;
}

.bundle-page__savings {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  background: #000;
  color: #fff;
  padding: 2px 7px;
  border-radius: 3px;
}

.bundle-page__description {
  font-size: 0.875rem;
  line-height: 1.6;
  margin-bottom: 1.5rem;
  color: rgba(var(--color-foreground), 0.75);
}

.bundle-page__components {
  border: 1px solid #ededed;
  border-radius: 8px;
  padding: 1rem 1.1rem;
  margin-bottom: 1.5rem;
  background: #ffffff;
}

.bundle-page__components-heading {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin: 0 0 0.75rem;
}

.bundle-page__component-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.bundle-page__component-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid #f5f5f5;
}

.bundle-page__component-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.bundle-page__component-img {
  width: 52px;
  height: 52px;
  object-fit: cover;
  border-radius: 4px;
  flex-shrink: 0;
  background: #f5f5f5;
}

.bundle-page__component-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.bundle-page__component-title {
  font-size: 0.8rem;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bundle-page__component-variant {
  font-size: 0.7rem;
  opacity: 0.55;
}

.bundle-page__add-btn {
  width: 100%;
  margin-top: 0.25rem;
}

.bundle-page__feedback {
  margin-top: 0.6rem;
  font-size: 0.75rem;
  min-height: 1.2em;
}

.bundle-page__feedback--success {
  color: #2a7a2a;
}

.bundle-page__feedback--error {
  color: #c0392b;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle Product",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Add Bundle to Cart"
    }
  ],
  "presets": [
    {
      "name": "Bundle Product"
    }
  ]
}
{% endschema %}
