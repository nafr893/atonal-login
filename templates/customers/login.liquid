{% layout 'theme' %}

{{ 'customer.css' | asset_url | stylesheet_tag }}

<style>
  .login-page {
    max-width: 30rem;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
    text-align: center;
  }

  .login-page h1 {
    margin-top: 0;
    margin-bottom: 0.8rem;
    font-size: 2rem;
  }

  .login-page .login-page__subtitle {
    font-size: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .login-page__field {
    margin-bottom: 0.8rem;
    text-align: left;
  }

  .login-page__label {
    display: block;
    font-size: 0.7rem;
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .login-page__input {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 0.5rem 0.7rem;
    font-size: 0.75rem;
    font-family: inherit;
    border: 0.1rem solid #f5f5f5;
    border-radius: var(--style-border-radius-inputs);
    background-color: #f9f9f9;
    color: rgb(var(--color-foreground));
    transition: border-color 0.15s ease;
    outline: none;
  }

  .login-page__input:focus {
    border-color: #d0d0d0;
  }

  .login-page__input::placeholder {
    color: rgba(var(--color-foreground), 0.35);
  }

  .login-page__submit {
    margin-top: 1.2rem;
    width: 100%;
  }

  .login-page__links {
    margin-top: 1rem;
    font-size: 0.7rem;
  }

  .login-page__links a {
    color: rgb(var(--color-foreground));
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .login-page .form-errors {
    background: rgba(220, 50, 50, 0.07);
    border-radius: var(--style-border-radius-inputs);
    padding: 0.6rem 0.8rem;
    margin-bottom: 1rem;
    text-align: left;
    font-size: 0.7rem;
    color: #c0392b;
  }

  .login-page .form-errors ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>

<div class="login-page">
  <h1>Wholesale Login</h1>

  {% if customer %}
    <p>You are already logged in.</p>
    <a href="{{ routes.account_url }}" class="button">Account</a>
  {% else %}
    <p class="login-page__subtitle">
      Create account? <a href="/pages/wholesale-registration-form">Create account</a>
    </p>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div class="form-errors">
          <ul>
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] | capitalize }}
                  {{ form.errors.messages[field] }}
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="login-page__field">
        <label class="login-page__label" for="CustomerEmail">Email</label>
        <input
          class="login-page__input"
          id="CustomerEmail"
          name="customer[email]"
          type="email"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          placeholder="Email"
          value="{{ form.email }}"
          required
        >
      </div>

      <div class="login-page__field">
        <label class="login-page__label" for="CustomerPassword">Password</label>
        <input
          class="login-page__input"
          id="CustomerPassword"
          name="customer[password]"
          type="password"
          autocomplete="current-password"
          placeholder="Password"
          required
        >
      </div>

      <button type="submit" class="button login-page__submit">
        Log in
      </button>

      <p class="login-page__links">
        <a href="#" id="forgot-toggle">Forgot your password?</a>
      </p>
    {%- endform -%}

    <div id="recover-form" style="display:none;margin-top:1.5rem;">
      <p class="login-page__subtitle" style="margin-bottom:1rem;">Enter your email and we'll send you a reset link.</p>
      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <p style="font-size:0.8rem;color:#2a7a2a;margin-bottom:1rem;">Check your email for a reset link.</p>
        {%- endif -%}
        {%- if form.errors -%}
          <div class="form-errors">
            <ul>
              {%- for field in form.errors -%}
                <li>
                  {%- if field == 'form' -%}{{ form.errors.messages[field] }}
                  {%- else -%}{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
        <div class="login-page__field">
          <label class="login-page__label" for="RecoverEmail">Email</label>
          <input class="login-page__input" id="RecoverEmail" name="email" type="email" autocomplete="email" placeholder="Email" required>
        </div>
        <button type="submit" class="button login-page__submit">Send Reset Link</button>
        <p class="login-page__links" style="margin-top:0.75rem;">
          <a href="#" id="recover-cancel">Back to login</a>
        </p>
      {%- endform -%}
    </div>

  {% endif %}
</div>

<script>
  (function () {
    var toggle = document.getElementById('forgot-toggle');
    var cancel = document.getElementById('recover-cancel');
    var recoverForm = document.getElementById('recover-form');
    var loginForm = document.querySelector('.login-page form');
    var loginLinks = document.querySelector('.login-page__links');

    if (toggle && recoverForm) {
      toggle.addEventListener('click', function (e) {
        e.preventDefault();
        recoverForm.style.display = 'block';
        if (loginForm) loginForm.style.display = 'none';
        if (loginLinks) loginLinks.style.display = 'none';
      });
    }

    if (cancel && recoverForm) {
      cancel.addEventListener('click', function (e) {
        e.preventDefault();
        recoverForm.style.display = 'none';
        if (loginForm) loginForm.style.display = 'block';
        if (loginLinks) loginLinks.style.display = 'block';
      });
    }

    {%- if recover.attempted -%}
      if (recoverForm && loginForm) {
        recoverForm.style.display = 'block';
        loginForm.style.display = 'none';
      }
    {%- endif -%}
  })();
</script>
