{% layout 'theme' %}

{{ 'customer.css' | asset_url | stylesheet_tag }}

<style>
  .activate-page {
    max-width: 30rem;
    margin: 0 auto;
    padding: 3rem 1rem 4rem;
    text-align: center;
  }

  .activate-page h1 {
    margin-top: 0;
    margin-bottom: 0.8rem;
    font-size: 2rem;
  }

  .activate-page__subtitle {
    font-size: 0.75rem;
    margin-bottom: 1.5rem;
    opacity: 0.65;
  }

  .activate-page__field {
    margin-bottom: 0.8rem;
    text-align: left;
  }

  .activate-page__label {
    display: block;
    font-size: 0.7rem;
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .activate-page__input {
    display: block;
    width: 100%;
    box-sizing: border-box;
    padding: 0.5rem 0.7rem;
    font-size: 0.75rem;
    font-family: inherit;
    border: 0.1rem solid #f5f5f5;
    border-radius: var(--style-border-radius-inputs);
    background-color: #f9f9f9;
    color: rgb(var(--color-foreground));
    transition: border-color 0.15s ease;
    outline: none;
  }

  .activate-page__input:focus {
    border-color: #d0d0d0;
  }

  .activate-page__input::placeholder {
    color: rgba(var(--color-foreground), 0.35);
  }

  .activate-page__submit {
    margin-top: 1.2rem;
    width: 100%;
  }

  .activate-page__links {
    margin-top: 1rem;
    font-size: 0.7rem;
  }

  .activate-page__links a {
    color: rgb(var(--color-foreground));
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .activate-page .form-errors {
    background: rgba(220, 50, 50, 0.07);
    border-radius: var(--style-border-radius-inputs);
    padding: 0.6rem 0.8rem;
    margin-bottom: 1rem;
    text-align: left;
    font-size: 0.7rem;
    color: #c0392b;
  }

  .activate-page .form-errors ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>

<div class="activate-page">
  <h1>Set Your Password</h1>
  <p class="activate-page__subtitle">Create a password to activate your account.</p>

  {%- form 'activate_customer_password' -%}
    {%- if form.errors -%}
      <div class="form-errors">
        <ul>
          {%- for field in form.errors -%}
            <li>
              {%- if field == 'form' -%}
                {{ form.errors.messages[field] }}
              {%- else -%}
                {{ form.errors.translated_fields[field] | capitalize }}
                {{ form.errors.messages[field] }}
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="activate-page__field">
      <label class="activate-page__label" for="Password">Password</label>
      <input
        class="activate-page__input"
        id="Password"
        name="customer[password]"
        type="password"
        autocomplete="new-password"
        placeholder="Password"
        required
      >
    </div>

    <div class="activate-page__field">
      <label class="activate-page__label" for="PasswordConfirmation">Confirm password</label>
      <input
        class="activate-page__input"
        id="PasswordConfirmation"
        name="customer[password_confirmation]"
        type="password"
        autocomplete="new-password"
        placeholder="Confirm password"
        required
      >
    </div>

    <button type="submit" class="button activate-page__submit">
      Activate Account
    </button>

    <p class="activate-page__links">
      <a href="{{ routes.account_login_url }}">Back to login</a>
    </p>
  {%- endform -%}
</div>
