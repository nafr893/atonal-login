{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-label="{{ 'accessibility.open_cart_drawer' | t }} {{ 'accessibility.cart_count' | t}}: {{ cart.item_count }}"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <span class="cart-drawer__heading h3 cart-drawer__heading--empty">
              {{ 'content.your_cart_is_empty' | t }}
            </span>

            <div class="cart-drawer__items">
              {% render 'cart-products' %}
            </div>
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <span class="cart-drawer__heading h5" style="text-transform: uppercase;">
            
           <!-- {{ 'content.cart_title' | t }} -->
              {{ 'Your Cart' }}
              {% render 'cart-bubble' %}
            </span>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

{% render 'cart-progress-bar' %}
<div class="wholesale-banner">
<p class="wholesale-message"> Sign up for a <a class="wholesale-link" href="https://atonalheadwear.com/pages/wholesale-registration-form"> wholesale account </a> for bulk discounts </p>
</div>


          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {%- if settings.cart_upsell_collection != blank -%}
                {%- assign upsell_col = collections[settings.cart_upsell_collection] -%}
              {%- endif -%}
              {%- if upsell_col.products.size > 0 -%}
                {%- assign upsell_heading = settings.cart_upsell_heading | default: 'Pairs well with' -%}
                <div class="cart-upsell">
                  <div class="cart-upsell__header">
                    <span class="cart-upsell__heading">{{ upsell_heading | upcase }}</span>
                    <div class="cart-upsell__arrows">
                      <button class="cart-upsell__arrow" data-dir="-1" aria-label="Previous">&#8249;</button>
                      <button class="cart-upsell__arrow" data-dir="1" aria-label="Next">&#8250;</button>
                    </div>
                  </div>
                  <div class="cart-upsell__track-wrapper">
                    <div class="cart-upsell__track">
                      {%- for product in upsell_col.products limit: 6 -%}
                        <div class="cart-upsell__slide">
                          <a href="{{ product.url }}" class="cart-upsell__img-wrap">
                            {%- if product.featured_image -%}
                              <img
                                src="{{ product.featured_image | image_url: width: 160 }}"
                                alt="{{ product.title | escape }}"
                                width="80"
                                height="80"
                                loading="lazy"
                              >
                            {%- endif -%}
                          </a>
                          <div class="cart-upsell__info">
                            <a href="{{ product.url }}" class="cart-upsell__title">{{ product.title }}</a>
                            <p class="cart-upsell__price">{{ product.price | money }}</p>
                            {%- assign color_option_index = nil -%}
                            {%- for option in product.options -%}
                              {%- if option == 'Color' or option == 'Colour' -%}
                                {%- assign color_option_index = forloop.index0 -%}
                              {%- endif -%}
                            {%- endfor -%}
                            {%- if color_option_index != nil -%}
                              <div class="cart-upsell__swatches">
                                {%- assign seen_colors = '' | split: '' -%}
                                {%- for variant in product.variants limit: 6 -%}
                                  {%- assign color_val = variant.options[color_option_index] -%}
                                  {%- unless seen_colors contains color_val -%}
                                    {%- assign seen_colors = seen_colors | push: color_val -%}
                                    {%- if variant.image -%}
                                      <span class="cart-upsell__swatch" style="background-image:url('{{ variant.image | image_url: width: 40 }}')" title="{{ color_val }}"></span>
                                    {%- else -%}
                                      <span class="cart-upsell__swatch cart-upsell__swatch--text" title="{{ color_val }}"></span>
                                    {%- endif -%}
                                  {%- endunless -%}
                                {%- endfor -%}
                              </div>
                            {%- endif -%}
                          </div>
                          <button
                            class="cart-upsell__add"
                            data-variant-id="{{ product.first_available_variant.id }}"
                            aria-label="Add {{ product.title | escape }} to cart"
                          >ADD</button>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {%- endif -%}

              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

<script>
  (function () {
    function initUpsell(drawer) {
      var wrap = drawer.querySelector('.cart-upsell');
      if (!wrap) return;
      var track = wrap.querySelector('.cart-upsell__track');
      var slides = wrap.querySelectorAll('.cart-upsell__slide');
      var total = slides.length;
      var current = 0;

      function show(index) {
        current = (index + total) % total;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
      }

      wrap.querySelectorAll('.cart-upsell__arrow').forEach(function (btn) {
        btn.addEventListener('click', function () {
          show(current + parseInt(btn.dataset.dir, 10));
        });
      });

      wrap.querySelectorAll('.cart-upsell__add').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.dataset.variantId;
          btn.disabled = true;
          btn.textContent = '...';
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id, quantity: 1 })
          })
            .then(function (r) { return r.json(); })
            .then(function () {
              btn.textContent = 'ADDED';
              setTimeout(function () {
                btn.disabled = false;
                btn.textContent = 'ADD';
              }, 1800);
              document.dispatchEvent(new CustomEvent('cart:refresh'));
            })
            .catch(function () {
              btn.disabled = false;
              btn.textContent = 'ADD';
            });
        });
      });
    }

    function setup() {
      document.querySelectorAll('cart-drawer-component').forEach(initUpsell);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setup);
    } else {
      setup();
    }
  })();
</script>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 18px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    padding-bottom: 0; 
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer__dialog {
    overflow: hidden;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
  }

.wholesale-banner {
width: 100%; 

padding-left: 20px;
padding-right: 20px;
border-radius: 2px; 
padding-bottom: 10px; 
}

.wholesale-message {
  padding: 6px 6px;
  background-color: #161616;
  border: 1px solid #eee;
  border-radius: 4px;
  text-align: center;
  color: white; 
  font-size: 12px; 
}

.wholesale-link {
  font-weight: bold;
  color: white; 
  text-decoration: underline;
}

.wholesale-link:hover {
color: white !important;
}

  .cart-upsell {
    margin: 0;
    padding: 12px 20px 4px;
    background-color: var(--color-background);
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .cart-upsell__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .cart-upsell__heading {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgb(var(--color-foreground));
  }

  .cart-upsell__arrows {
    display: flex;
    gap: 2px;
  }

  .cart-upsell__arrow {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.4rem;
    line-height: 1;
    padding: 0 4px;
    color: rgb(var(--color-foreground));
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .cart-upsell__arrow:hover {
    opacity: 1;
  }

  .cart-upsell__track-wrapper {
    overflow: hidden;
  }

  .cart-upsell__track {
    display: flex;
    transition: transform 0.3s ease;
  }

  .cart-upsell__slide {
    min-width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 0 10px;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 6px;
    padding: 10px 12px;
    background: var(--color-background);
  }

  .cart-upsell__img-wrap {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    overflow: hidden;
    border-radius: 4px;
    background: rgba(var(--color-foreground), 0.04);
    display: block;
  }

  .cart-upsell__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-upsell__info {
    flex: 1;
    min-width: 0;
  }

  .cart-upsell__title {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 2px;
  }

  .cart-upsell__price {
    font-size: 0.75rem;
    margin: 0 0 6px;
    color: rgb(var(--color-foreground));
  }

  .cart-upsell__swatches {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .cart-upsell__swatch {
    width: 18px;
    height: 18px;
    border-radius: 2px;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    background-size: cover;
    background-position: center;
    display: inline-block;
  }

  .cart-upsell__swatch--text {
    background-color: rgba(var(--color-foreground), 0.12);
  }

  .cart-upsell__add {
    flex-shrink: 0;
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border: none;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 8px 12px;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .cart-upsell__add:hover {
    opacity: 0.8;
  }

  .cart-upsell__add:disabled {
    opacity: 0.5;
    cursor: default;
  }

{% endstylesheet %}
