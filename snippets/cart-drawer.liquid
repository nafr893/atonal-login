{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-label="{{ 'accessibility.open_cart_drawer' | t }} {{ 'accessibility.cart_count' | t}}: {{ cart.item_count }}"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <span class="cart-drawer__heading h3 cart-drawer__heading--empty">
              {{ 'content.your_cart_is_empty' | t }}
            </span>

            <div class="cart-drawer__items">
              {% render 'cart-products' %}
            </div>
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <span class="cart-drawer__heading h5" style="text-transform: uppercase;">
            
           <!-- {{ 'content.cart_title' | t }} -->
              {{ 'Your Cart' }}
              {% render 'cart-bubble' %}
            </span>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

{% render 'cart-progress-bar' %}
<div class="wholesale-banner">
<p class="wholesale-message"> Sign up for a <a class="wholesale-link" href="https://atonalheadwear.com/pages/wholesale-registration-form"> wholesale account </a> for bulk discounts </p>
</div>


          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
            <scroll-hint
              class="cart-drawer__items"
            >
              {% render 'cart-products' %}
            </scroll-hint>

            <div class="cart-drawer__summary">
              {%- assign cu_handles = '' -%}
              {%- assign cu_liq_prices = '' -%}
              {%- assign cu_is_wholesale = false -%}
              {%- if customer -%}
                {%- if customer.tags contains 'wg-wholesale' or customer.tags contains 'wholesale' -%}
                  {%- assign cu_is_wholesale = true -%}
                {%- endif -%}
              {%- endif -%}
              {%- if settings.cart_upsell_product_1 != blank -%}
                {%- assign cu_handles = cu_handles | append: settings.cart_upsell_product_1 | append: ',' -%}
                {%- assign cu_p = all_products[settings.cart_upsell_product_1].price | plus: 0 -%}
                {%- if cu_p > 0 -%}{%- assign cu_liq_prices = cu_liq_prices | append: settings.cart_upsell_product_1 | append: ':' | append: cu_p | append: ';' -%}{%- endif -%}
              {%- endif -%}
              {%- if settings.cart_upsell_product_2 != blank -%}
                {%- assign cu_handles = cu_handles | append: settings.cart_upsell_product_2 | append: ',' -%}
                {%- assign cu_p = all_products[settings.cart_upsell_product_2].price | plus: 0 -%}
                {%- if cu_p > 0 -%}{%- assign cu_liq_prices = cu_liq_prices | append: settings.cart_upsell_product_2 | append: ':' | append: cu_p | append: ';' -%}{%- endif -%}
              {%- endif -%}
              {%- if settings.cart_upsell_product_3 != blank -%}
                {%- assign cu_handles = cu_handles | append: settings.cart_upsell_product_3 | append: ',' -%}
                {%- assign cu_p = all_products[settings.cart_upsell_product_3].price | plus: 0 -%}
                {%- if cu_p > 0 -%}{%- assign cu_liq_prices = cu_liq_prices | append: settings.cart_upsell_product_3 | append: ':' | append: cu_p | append: ';' -%}{%- endif -%}
              {%- endif -%}
              {%- if settings.cart_upsell_product_4 != blank -%}
                {%- assign cu_handles = cu_handles | append: settings.cart_upsell_product_4 | append: ',' -%}
                {%- assign cu_p = all_products[settings.cart_upsell_product_4].price | plus: 0 -%}
                {%- if cu_p > 0 -%}{%- assign cu_liq_prices = cu_liq_prices | append: settings.cart_upsell_product_4 | append: ':' | append: cu_p | append: ';' -%}{%- endif -%}
              {%- endif -%}
              {%- if settings.cart_upsell_product_5 != blank -%}
                {%- assign cu_handles = cu_handles | append: settings.cart_upsell_product_5 | append: ',' -%}
                {%- assign cu_p = all_products[settings.cart_upsell_product_5].price | plus: 0 -%}
                {%- if cu_p > 0 -%}{%- assign cu_liq_prices = cu_liq_prices | append: settings.cart_upsell_product_5 | append: ':' | append: cu_p | append: ';' -%}{%- endif -%}
              {%- endif -%}
              {%- if cu_handles != blank -%}
                <div class="cart-upsell"
                  data-handles="{{ cu_handles | remove_last: ',' }}"
                  data-heading="{{ settings.cart_upsell_heading | default: 'Pairs well with' | escape }}"
                  data-wholesale="{{ cu_is_wholesale }}"
                  data-liquid-prices="{{ cu_liq_prices }}">
                </div>
              {%- endif -%}

              {% render 'cart-summary' %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

<script>
(function () {
  function money(price) {
    return '$' + parseFloat(price).toFixed(2);
  }

  function moneyFromCents(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  function parseLiquidPrices(str) {
    var map = {};
    if (!str) return map;
    str.split(';').forEach(function (pair) {
      var idx = pair.indexOf(':');
      if (idx > 0) {
        var handle = pair.slice(0, idx).trim();
        var cents = parseInt(pair.slice(idx + 1), 10);
        if (handle && !isNaN(cents) && cents > 0) map[handle] = cents;
      }
    });
    return map;
  }

  var ARROW_STYLE = 'display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;background:#fff;border:1px solid rgba(0,0,0,0.18);border-radius:4px;cursor:pointer;font-size:1.1rem;line-height:0;color:#000;padding:0;';

  var cuLoading = new WeakSet();
  var productCache = {};
  var cartPriceMap = {};

  function startLoad(wrap) {
    if (cuLoading.has(wrap)) return;
    var handlesRaw = wrap.dataset.handles;
    if (handlesRaw) {
      var cachedProds = handlesRaw.split(',')
        .map(function (h) { return productCache[h.trim()]; })
        .filter(Boolean);
      if (cachedProds.length) {
        var liqPrices = parseLiquidPrices(wrap.dataset.liquidPrices || '');
        fetch('/cart.js')
          .then(function (r) { return r.json(); })
          .then(function (cart) {
            syncCartPrices(cart);
            buildCarousel(wrap, cachedProds, liqPrices);
          })
          .catch(function () { buildCarousel(wrap, cachedProds, liqPrices); });
        return;
      }
    }
    cuLoading.add(wrap);
    loadUpsell(wrap).then(
      function () { cuLoading.delete(wrap); },
      function () { cuLoading.delete(wrap); }
    );
  }

  function refreshCartSection(savedHandles, savedHeading, savedLiqPrices) {
    var cartComp = document.querySelector('cart-items-component');
    if (!cartComp) return;
    var sid = cartComp.dataset.sectionId;
    if (!sid) return;

    Promise.all([
      fetch('/?sections=' + sid).then(function (r) { return r.json(); }),
      fetch('/cart.js').then(function (r) { return r.json(); }).catch(function () { return null; })
    ])
      .then(function (results) {
        syncCartPrices(results[1]);

        var html = results[0][sid];
        if (!html) return;
        var doc = new DOMParser().parseFromString(html, 'text/html');
        var newComp = doc.querySelector('cart-items-component');
        if (!newComp) return;
        cartComp.innerHTML = newComp.innerHTML;

        var newUpsell = cartComp.querySelector('.cart-upsell');
        if (newUpsell && savedHandles) {
          newUpsell.dataset.handles = savedHandles;
          newUpsell.dataset.heading = savedHeading || 'Pairs well with';
          newUpsell.dataset.liquidPrices = savedLiqPrices || '';
          var cachedProds = savedHandles.split(',')
            .map(function (h) { return productCache[h.trim()]; })
            .filter(Boolean);
          if (cachedProds.length) {
            buildCarousel(newUpsell, cachedProds, parseLiquidPrices(savedLiqPrices || ''));
          } else {
            startLoad(newUpsell);
          }
        }
      })
      .catch(function () {});
  }

  function bindAdd(wrap) {
    var handles = wrap.dataset.handles;
    var heading = wrap.dataset.heading;
    var liqPrices = wrap.dataset.liquidPrices || '';
    wrap.querySelectorAll('.cart-upsell__add').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.dataset.variantId;
        btn.disabled = true;
        btn.textContent = '...';
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
        })
          .then(function (r) { return r.json(); })
          .then(function () {
            btn.textContent = 'ADDED';
            setTimeout(function () { btn.disabled = false; btn.textContent = 'ADD'; }, 1800);
            refreshCartSection(handles, heading, liqPrices);
          })
          .catch(function () { btn.disabled = false; btn.textContent = 'ADD'; });
      });
    });
  }

  function computePrice(p, variant, liqPrices) {
    var variantPrice = variant ? parseFloat(variant.price) : 0;
    var variantCompare = variant && variant.compare_at_price ? parseFloat(variant.compare_at_price) : 0;
    var liqCents = liqPrices && liqPrices[p.handle];
    var cartDiscount = cartPriceMap[p.handle];
    var currentPrice, wasPrice;
    if (cartDiscount) {
      currentPrice = moneyFromCents(cartDiscount.final);
      wasPrice = moneyFromCents(cartDiscount.original);
    } else if (liqCents) {
      currentPrice = moneyFromCents(liqCents);
      wasPrice = variantPrice > liqCents / 100 ? money(variant.price) : null;
    } else if (variantCompare > variantPrice) {
      currentPrice = money(variant.price);
      wasPrice = money(variant.compare_at_price);
    } else {
      currentPrice = variant ? money(variant.price) : '';
      wasPrice = null;
    }
    return wasPrice
      ? '<s style="opacity:0.45;font-size:0.7rem;text-decoration:line-through;">' + wasPrice + '</s>&nbsp;' + currentPrice
      : currentPrice;
  }

  function bindVariantSelects(wrap, products, liqPrices) {
    wrap.querySelectorAll('.cu-variant-select').forEach(function (select) {
      select.addEventListener('change', function () {
        var slide = select.closest('.cart-upsell__slide');
        if (!slide) return;
        var handle = select.dataset.handle;
        var p = null;
        for (var i = 0; i < products.length; i++) {
          if (products[i].handle === handle) { p = products[i]; break; }
        }
        var opt = select.options[select.selectedIndex];
        var btn = slide.querySelector('.cart-upsell__add');
        if (btn) btn.dataset.variantId = opt.value;
        var priceEl = slide.querySelector('.cu-price');
        if (priceEl && p) {
          priceEl.innerHTML = computePrice(
            p,
            { price: opt.dataset.price, compare_at_price: opt.dataset.compare || null },
            liqPrices
          );
        }
        var imgEl = slide.querySelector('.cu-thumb');
        if (imgEl && p) {
          var variantId = parseInt(opt.value, 10);
          var newSrc = '';
          if (p.images) {
            for (var j = 0; j < p.images.length; j++) {
              if (p.images[j].variant_ids && p.images[j].variant_ids.indexOf(variantId) !== -1) {
                newSrc = p.images[j].src;
                break;
              }
            }
          }
          if (!newSrc) newSrc = opt.dataset.img || (p.images && p.images.length ? p.images[0].src : '');
          if (newSrc) imgEl.setAttribute('src', newSrc);
        }
      });
    });
  }

  function buildCarousel(wrap, products, liqPrices) {
    var heading = (wrap.dataset.heading || 'Pairs well with').toUpperCase();
    var SELECT_STYLE = 'margin-top:5px;font-size:0.68rem;padding:3px 5px;border:1px solid rgba(0,0,0,0.15);border-radius:4px;background:var(--color-background);color:inherit;width:100%;max-width:150px;cursor:pointer;outline:none;';
    var slides = products.map(function (p) {
      var img = p.images && p.images.length
        ? '<img class="cu-thumb" src="' + p.images[0].src + '" alt="" width="68" height="68" style="width:68px;height:68px;object-fit:cover;display:block;">'
        : '';
      var defaultVariant = p.variants && p.variants[0];
      var hasVariants = p.variants && p.variants.length > 1 &&
        !(p.variants.length === 1 && p.variants[0].title === 'Default Title');
      var priceHtml = computePrice(p, defaultVariant, liqPrices);
      var vid = defaultVariant ? defaultVariant.id : '';
      var variantSelect = '';
      if (hasVariants) {
        variantSelect = '<select class="cu-variant-select" data-handle="' + p.handle + '" style="' + SELECT_STYLE + '">'
          + p.variants.map(function (v) {
              return '<option value="' + v.id + '" data-price="' + (v.price || '') + '" data-compare="' + (v.compare_at_price || '') + '" data-img="' + (v.featured_image ? v.featured_image.src : '') + '"'
                + (v.available === false ? ' disabled' : '') + '>'
                + v.title + (v.available === false ? ' – Sold out' : '')
                + '</option>';
            }).join('')
          + '</select>';
      }
      return '<div class="cart-upsell__slide" style="flex:0 0 100%;min-width:0;box-sizing:border-box;display:flex;align-items:center;gap:12px;padding:10px 12px;border:1px solid rgba(0,0,0,0.09);border-radius:6px;">'
        + '<a href="/products/' + p.handle + '" style="flex-shrink:0;width:68px;height:68px;overflow:hidden;border-radius:4px;display:block;background:#f5f5f5;">' + img + '</a>'
        + '<div style="flex:1;min-width:0;">'
          + '<a href="/products/' + p.handle + '" style="display:block;font-size:0.8rem;font-weight:600;text-decoration:none;color:inherit;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">' + p.title + '</a>'
          + '<p class="cu-price" style="font-size:0.75rem;margin:3px 0 0;">' + priceHtml + '</p>'
          + variantSelect
        + '</div>'
        + '<button class="cart-upsell__add" data-variant-id="' + vid + '" style="flex-shrink:0;background:#000;color:#fff;border:none;border-radius:4px;font-size:0.65rem;font-weight:700;letter-spacing:0.06em;padding:8px 12px;cursor:pointer;">ADD</button>'
        + '</div>';
    }).join('');

    var current = 0;
    var total = products.length;

    wrap.innerHTML =
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;padding:0 12px;">'
        + '<span style="font-size:0.85rem;font-weight:700;letter-spacing:0.08em;">' + heading + '</span>'
        + '<div style="display:flex;gap:4px;">'
          + '<button class="cu-prev" style="' + ARROW_STYLE + '">&#8249;</button>'
          + '<button class="cu-next" style="' + ARROW_STYLE + '">&#8250;</button>'
        + '</div>'
      + '</div>'
      + '<div style="width:100%;overflow:hidden;">'
        + '<div class="cu-track" style="display:flex;width:100%;transition:transform 0.3s ease;">' + slides + '</div>'
      + '</div>';

    var track = wrap.querySelector('.cu-track');
    function show(i) {
      current = (i + total) % total;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
    }
    wrap.querySelector('.cu-prev').addEventListener('click', function () { show(current - 1); });
    wrap.querySelector('.cu-next').addEventListener('click', function () { show(current + 1); });
    bindVariantSelects(wrap, products, liqPrices);
    bindAdd(wrap);
  }

  function syncCartPrices(cart) {
    cartPriceMap = {};
    if (cart && cart.items) {
      cart.items.forEach(function (item) {
        if (item.original_price > item.final_price) {
          cartPriceMap[item.handle] = { final: item.final_price, original: item.original_price };
        }
      });
    }
  }

  async function loadUpsell(wrap) {
    var handlesRaw = wrap.dataset.handles;
    if (!handlesRaw) return;
    var handles = handlesRaw.split(',').map(function (h) { return h.trim(); }).filter(Boolean);
    if (!handles.length) return;
    var liqPrices = parseLiquidPrices(wrap.dataset.liquidPrices || '');

    var cartFetch = fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(syncCartPrices)
      .catch(function () {});

    var products = [];
    for (var i = 0; i < handles.length; i++) {
      try {
        var res = await fetch('/products/' + handles[i] + '.json');
        if (res.ok) {
          var data = await res.json();
          if (data && data.product) products.push(data.product);
        }
      } catch (e) {}
    }

    await cartFetch;

    if (products.length) {
      products.forEach(function (p) { productCache[p.handle] = p; });
      buildCarousel(wrap, products, liqPrices);
    }
  }

  function observeCartChanges() {
    var target = document.querySelector('cart-drawer-component') || document.body;
    new MutationObserver(function () {
      target.querySelectorAll('.cart-upsell[data-handles]').forEach(function (wrap) {
        if (!wrap.querySelector('.cu-track')) startLoad(wrap);
      });
    }).observe(target, { childList: true, subtree: true });
  }

  function init() {
    document.querySelectorAll('.cart-upsell[data-handles]').forEach(startLoad);
    observeCartChanges();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 18px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    padding-bottom: 0; 
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
    }
  }

  .cart-drawer__dialog {
    overflow: hidden;
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__content {
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
    gap: 0 !important;
  }

  .cart-drawer__summary .cart__ctas {
    width: 100%;
    margin-top: var(--gap-xl, 1.5rem);
  }

.wholesale-banner {
width: 100%; 

padding-left: 20px;
padding-right: 20px;
border-radius: 2px; 
padding-bottom: 10px; 
}

.wholesale-message {
  padding: 6px 6px;
  background-color: #161616;
  border: 1px solid #eee;
  border-radius: 4px;
  text-align: center;
  color: white; 
  font-size: 12px; 
}

.wholesale-link {
  font-weight: bold;
  color: white; 
  text-decoration: underline;
}

.wholesale-link:hover {
color: white !important;
}

  .cart-upsell {
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
    overflow: hidden !important;
    margin: 0;
    padding: 10px 0 4px;
    background-color: var(--color-background);
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .cart-upsell__info {
    flex: 1;
    min-width: 0;
  }

  scroll-hint.cart-drawer__items {
    -webkit-mask-image: none !important;
    mask-image: none !important;
  }

  .cart-upsell__title {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 2px;
  }

  .cart-upsell__price {
    font-size: 0.75rem;
    margin: 0 0 6px;
    color: rgb(var(--color-foreground));
  }

  .cart-upsell__swatches {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }

  .cart-upsell__swatch {
    width: 18px;
    height: 18px;
    border-radius: 2px;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    background-size: cover;
    background-position: center;
    display: inline-block;
  }

  .cart-upsell__swatch--text {
    background-color: rgba(var(--color-foreground), 0.12);
  }

  .cart-upsell__add {
    flex-shrink: 0;
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    border: none;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 8px 12px;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .cart-upsell__add:hover {
    opacity: 0.8;
  }

  .cart-upsell__add:disabled {
    opacity: 0.5;
    cursor: default;
  }

{% endstylesheet %}
